local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")
local Lighting = game:GetService("Lighting")
local player = Players.LocalPlayer

local KEYFILE = "RelzFPSKey.txt"
local ValidKeys = {"LZRZ_1443381972830011928"}

local function validateKey(key)
    for _, v in pairs(ValidKeys) do
        if key == v then return true end
    end
    return false
end

local function loadFPSHub()
    local gui = Instance.new("ScreenGui")
    gui.Name = "RelzFPS"
    gui.ResetOnSpawn = false
    gui.IgnoreGuiInset = true
    gui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    gui.Parent = player:WaitForChild("PlayerGui")

    local hue = 0
    local expanded = true
    local boostOn = false
    local ultraBoostOn = false

    -- Notification function
    local function showNotif(text)
        local existing = player.PlayerGui:FindFirstChild("RelzNotif")
        if existing then existing:Destroy() end

        local notifGui = Instance.new("ScreenGui")
        notifGui.Name = "RelzNotif"
        notifGui.ResetOnSpawn = false
        notifGui.IgnoreGuiInset = true
        notifGui.Parent = player.PlayerGui

        local notifFrame = Instance.new("Frame")
        notifFrame.Size = UDim2.fromOffset(260, 45)
        notifFrame.Position = UDim2.new(1, 10, 1, -70)
        notifFrame.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
        notifFrame.BorderSizePixel = 0
        notifFrame.Parent = notifGui
        Instance.new("UICorner", notifFrame).CornerRadius = UDim.new(0, 8)

        local notifBorder = Instance.new("UIStroke")
        notifBorder.Thickness = 2
        notifBorder.Parent = notifFrame
        task.spawn(function()
            local h = 0
            while notifFrame and notifFrame.Parent do
                h = (h + 2) % 360
                notifBorder.Color = Color3.fromHSV(h/360, 1, 1)
                task.wait(0.03)
            end
        end)

        local notifLabel = Instance.new("TextLabel")
        notifLabel.Size = UDim2.new(1, -10, 1, 0)
        notifLabel.Position = UDim2.new(0, 5, 0, 0)
        notifLabel.BackgroundTransparency = 1
        notifLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
        notifLabel.Text = text
        notifLabel.TextScaled = true
        notifLabel.Font = Enum.Font.GothamBold
        notifLabel.Parent = notifFrame

        TweenService:Create(notifFrame, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
            Position = UDim2.new(1, -270, 1, -70)
        }):Play()

        task.delay(3, function()
            if notifFrame and notifFrame.Parent then
                TweenService:Create(notifFrame, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
                    Position = UDim2.new(1, 10, 1, -70)
                }):Play()
                task.wait(0.3)
                notifGui:Destroy()
            end
        end)
    end

    -- Main Frame (GRAY background)
    local Main = Instance.new("Frame")
    Main.Size = UDim2.fromOffset(320, 290)
    Main.Position = UDim2.new(0, 10, 0, 100)
    Main.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
    Main.BorderSizePixel = 0
    Main.ClipsDescendants = true
    Main.Parent = gui
    Instance.new("UICorner", Main).CornerRadius = UDim.new(0, 10)

    -- Rainbow border
    local Border = Instance.new("UIStroke")
    Border.Thickness = 3
    Border.Parent = Main
    task.spawn(function()
        while gui and gui.Parent do
            hue = (hue + 1) % 360
            Border.Color = Color3.fromHSV(hue/360, 1, 1)
            task.wait(0.03)
        end
    end)

    -- Draggable
    local dragging, dragStart, startPos
    Main.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = Main.Position
        end
    end)
    Main.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseMovement) then
            local delta = input.Position - dragStart
            Main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    Main.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)

    -- + / - Toggle top right
    local ToggleBtn = Instance.new("TextButton")
    ToggleBtn.Size = UDim2.fromOffset(30, 30)
    ToggleBtn.Position = UDim2.new(1, -35, 0, 5)
    ToggleBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
    ToggleBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    ToggleBtn.Text = "-"
    ToggleBtn.TextScaled = true
    ToggleBtn.Font = Enum.Font.GothamBold
    ToggleBtn.BorderSizePixel = 0
    ToggleBtn.ZIndex = 5
    ToggleBtn.Parent = Main
    Instance.new("UICorner", ToggleBtn).CornerRadius = UDim.new(0, 6)

    -- Title (DARK GRAY color)
    local Title = Instance.new("TextLabel")
    Title.Size = UDim2.new(1, -45, 0, 30)
    Title.Position = UDim2.new(0, 10, 0, 8)
    Title.BackgroundTransparency = 1
    Title.TextColor3 = Color3.fromRGB(90, 90, 90)
    Title.Text = "RelzExxploitz FPS BOOSTER"
    Title.TextScaled = true
    Title.Font = Enum.Font.GothamBold
    Title.TextXAlignment = Enum.TextXAlignment.Left
    Title.Parent = Main

    -- FPS Label (DARK GRAY, updates every 0.5s so its readable)
    local FPSLabel = Instance.new("TextLabel")
    FPSLabel.Size = UDim2.new(1, -10, 0, 25)
    FPSLabel.Position = UDim2.new(0, 10, 0, 40)
    FPSLabel.BackgroundTransparency = 1
    FPSLabel.TextColor3 = Color3.fromRGB(90, 90, 90)
    FPSLabel.Text = "FPS: --"
    FPSLabel.TextScaled = true
    FPSLabel.Font = Enum.Font.GothamBold
    FPSLabel.TextXAlignment = Enum.TextXAlignment.Left
    FPSLabel.Parent = Main

    -- FPS updates every 0.5 seconds so player can read it
    local fpsAccum = 0
    local fpsCount = 0
    RunService.Heartbeat:Connect(function(delta)
        if FPSLabel and FPSLabel.Parent then
            fpsAccum = fpsAccum + delta
            fpsCount = fpsCount + 1
            if fpsAccum >= 0.5 then
                FPSLabel.Text = "FPS: " .. math.floor(fpsCount / fpsAccum)
                fpsAccum = 0
                fpsCount = 0
            end
        end
    end)

    -- Divider
    local Divider = Instance.new("Frame")
    Divider.Size = UDim2.new(1, -20, 0, 1)
    Divider.Position = UDim2.new(0, 10, 0, 72)
    Divider.BackgroundColor3 = Color3.fromRGB(80, 80, 80)
    Divider.BorderSizePixel = 0
    Divider.Parent = Main

    -- Content frame
    local Content = Instance.new("Frame")
    Content.Size = UDim2.new(1, 0, 1, -80)
    Content.Position = UDim2.new(0, 0, 0, 78)
    Content.BackgroundTransparency = 1
    Content.Parent = Main

    -- Button maker with BLACK outline
    local function makeBtn(text, yPos, bgColor, txtColor, active, cb)
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(1, -20, 0, 42)
        btn.Position = UDim2.new(0, 10, 0, yPos)
        btn.BackgroundColor3 = bgColor or Color3.fromRGB(55, 55, 55)
        btn.TextColor3 = txtColor or Color3.fromRGB(255, 255, 255)
        btn.Text = text
        btn.TextScaled = true
        btn.Font = Enum.Font.GothamBold
        btn.BorderSizePixel = 0
        btn.AutoButtonColor = active ~= false
        btn.Active = active ~= false
        btn.Parent = Content
        Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 8)

        -- Black outline on every button
        local stroke = Instance.new("UIStroke")
        stroke.Color = Color3.fromRGB(0, 0, 0)
        stroke.Thickness = 2
        stroke.Parent = btn

        if cb then btn.MouseButton1Click:Connect(cb) end
        return btn
    end

    -- BOOST button (red when OFF, green when ON)
    local boostBtn = makeBtn("BOOST: OFF", 5, Color3.fromRGB(55, 55, 55), Color3.fromRGB(255, 60, 60))

    boostBtn.MouseButton1Click:Connect(function()
        boostOn = not boostOn
        if boostOn then
            -- Fix: Only remove effects/shadows/particles, dont change brightness
            Lighting.GlobalShadows = false
            settings().Rendering.QualityLevel = Enum.QualityLevel.Level01

            for _, e in pairs(Lighting:GetChildren()) do
                if e:IsA("BlurEffect") or e:IsA("DepthOfFieldEffect") or e:IsA("SunRaysEffect") or e:IsA("ColorCorrectionEffect") or e:IsA("BloomEffect") then
                    e.Enabled = false
                end
            end

            for _, obj in pairs(workspace:GetDescendants()) do
                if obj:IsA("Smoke") or obj:IsA("Fire") or obj:IsA("Sparkles") or obj:IsA("ParticleEmitter") then
                    obj.Enabled = false
                elseif obj:IsA("Decal") or obj:IsA("Texture") then
                    obj.Transparency = 1
                end
            end

            workspace.Terrain.Decoration = false
            boostBtn.Text = "BOOST: ON"
            boostBtn.TextColor3 = Color3.fromRGB(0, 255, 100)
            showNotif("FPS Booster = Activated! ✅")
        else
            Lighting.GlobalShadows = true
            settings().Rendering.QualityLevel = Enum.QualityLevel.Automatic

            for _, e in pairs(Lighting:GetChildren()) do
                if e:IsA("BlurEffect") or e:IsA("DepthOfFieldEffect") or e:IsA("SunRaysEffect") or e:IsA("ColorCorrectionEffect") or e:IsA("BloomEffect") then
                    e.Enabled = true
                end
            end

            for _, obj in pairs(workspace:GetDescendants()) do
                if obj:IsA("Smoke") or obj:IsA("Fire") or obj:IsA("Sparkles") or obj:IsA("ParticleEmitter") then
                    obj.Enabled = true
                elseif obj:IsA("Decal") or obj:IsA("Texture") then
                    obj.Transparency = 0
                end
            end

            workspace.Terrain.Decoration = true
            boostBtn.Text = "BOOST: OFF"
            boostBtn.TextColor3 = Color3.fromRGB(255, 60, 60)
            showNotif("FPS Booster = Deactivated!")
        end
    end)

    -- ULTRA BOOST button (grayed out, coming soon)
    makeBtn("ULTRA BOOST (SOON)", 55, Color3.fromRGB(40, 40, 40), Color3.fromRGB(80, 80, 80), false)

    -- MAX BOOST button (grayed out for future)
    makeBtn("MAX BOOST (SOON)", 105, Color3.fromRGB(40, 40, 40), Color3.fromRGB(80, 80, 80), false)

    -- Owner label
    local OwnerLabel = Instance.new("TextLabel")
    OwnerLabel.Size = UDim2.new(1, -20, 0, 20)
    OwnerLabel.Position = UDim2.new(0, 10, 0, 155)
    OwnerLabel.BackgroundTransparency = 1
    OwnerLabel.TextColor3 = Color3.fromRGB(80, 80, 80)
    OwnerLabel.Text = "Owner: bright007n7"
    OwnerLabel.TextScaled = true
    OwnerLabel.Font = Enum.Font.Gotham
    OwnerLabel.Parent = Content

    -- + / - toggle logic
    ToggleBtn.MouseButton1Click:Connect(function()
        expanded = not expanded
        if expanded then
            TweenService:Create(Main, TweenInfo.new(0.3, Enum.EasingStyle.Quad), {
                Size = UDim2.fromOffset(320, 290)
            }):Play()
            ToggleBtn.Text = "-"
        else
            TweenService:Create(Main, TweenInfo.new(0.3, Enum.EasingStyle.Quad), {
                Size = UDim2.fromOffset(320, 75)
            }):Play()
            ToggleBtn.Text = "+"
        end
    end)

    task.wait(1)
    showNotif("RelzExxploitz Loaded! ✅")
end

