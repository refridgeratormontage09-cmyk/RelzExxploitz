end

-- Check saved key
local success, savedKey = pcall(function()
    return readfile(KEYFILE)
end)

if success and savedKey and savedKey ~= "" then
    if validateKey(savedKey:gsub("%s+", "")) then
        loadFPSHub()
    else
        pcall(function() writefile(KEYFILE, "") end)
        showKeyGui()
    end
else
    showKeyGui()
end
